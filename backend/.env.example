# Lattica Environment Configuration
# Copy this to .env and fill in your values

# --- LLM Provider Settings (for AI Deep Dive remediation) ---
# Default provider: gemini, openai, claude, or ollama
REMEDIATION_PROVIDER=gemini
# API key for the default provider (users can override per-request via the UI)
# Gemini free tier: https://aistudio.google.com/apikey
REMEDIATION_API_KEY=
# Optional: override the default model (leave blank for provider default)
REMEDIATION_MODEL=

# Legacy: used as fallback if REMEDIATION_API_KEY is not set
ANTHROPIC_API_KEY=

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./lattica.db

# --- Server ---
HOST=0.0.0.0
PORT=8000
