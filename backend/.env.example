# Lattica Environment Configuration
# Copy this to .env and fill in your values

# Default Anthropic API key used by the app.
# Users can override this per-session via the UI settings.
ANTHROPIC_API_KEY=your-api-key-here

# Database URL (SQLite for local dev)
DATABASE_URL=sqlite+aiosqlite:///./lattica.db

# FastAPI settings
HOST=0.0.0.0
PORT=8000
